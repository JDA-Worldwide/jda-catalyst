# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=                # Editor/Admin token — used by seed script + contact form (write ops)
SANITY_API_READ_TOKEN=           # Viewer token — used by Live Content API + Draft Mode (read-only)

# Resend
RESEND_API_KEY=
CONTACT_FORM_SENDER=noreply@yourdomain.com
CONTACT_FORM_RECIPIENT=info@yourdomain.com

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
