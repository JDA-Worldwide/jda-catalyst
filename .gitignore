# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example

# vercel
.vercel

# Sanity org Dashboard — generated by `npm run studio:manifest` / `npm run build`
/public/studio/static/*
!/public/studio/static/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
