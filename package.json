{
  "name": "jda-catalyst",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "studio:manifest": "sanity manifest extract --path public/studio/static",
    "studio:schema:deploy": "sanity schema deploy --manifest-dir public/studio/static --no-extract-manifest",
    "build:next": "next build",
    "build": "npm run studio:manifest && npm run studio:schema:deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "node --env-file=.env.local scripts/seed.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.2",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/image-url": "^2.0.3",
    "@sanity/vision": "^5.13.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "next": "16.1.6",
    "next-sanity": "^12.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "sanity": "^5.13.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
